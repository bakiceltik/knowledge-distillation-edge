\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces t-SNE projection of the distilled student's 1024-dimensional penultimate embeddings on the Cassava single-split test set. The majority \emph  {mosaic disease} class separates cleanly, while the minority classes overlap, mirroring the per-class scores (Table~\ref {tab:perclass}) and the confusion matrix (Figure~\ref {fig:cm}).}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:tsne}{{2}{6}{t-SNE projection of the distilled student's 1024-dimensional penultimate embeddings on the Cassava single-split test set. The majority \emph {mosaic disease} class separates cleanly, while the minority classes overlap, mirroring the per-class scores (Table~\ref {tab:perclass}) and the confusion matrix (Figure~\ref {fig:cm})}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VII}{\ignorespaces Comparison with published results on the same datasets. The Cassava rows of Liu et al.\ use the same Kaggle release and the same five classes as ours, so the architectures are directly comparable; the evaluation protocol still differs (their 90/10 split vs.\ our stratified five-fold cross-validation), as does Mohanty et al.'s 80/20 PlantVillage split. Literature values are as reported by the cited authors. Our Cassava rows are mean~$\pm $~SD over five folds; our PlantVillage rows are single-split. Parameter counts marked $\approx $ are the standard ImageNet variants of the cited architectures, adjusted for the 38-class head; Too et al.\ \cite  {too2019pruned} report their pruning as a relative reduction rather than an absolute count. Our parameter counts differ slightly between the two datasets because the classifier head is sized to the number of classes (38 for PlantVillage, 5 for Cassava); the backbones are identical.}}{7}{table.7}\protected@file@percent }
\newlabel{tab:literature}{{VII}{7}{Comparison with published results on the same datasets. The Cassava rows of Liu et al.\ use the same Kaggle release and the same five classes as ours, so the architectures are directly comparable; the evaluation protocol still differs (their 90/10 split vs.\ our stratified five-fold cross-validation), as does Mohanty et al.'s 80/20 PlantVillage split. Literature values are as reported by the cited authors. Our Cassava rows are mean~$\pm $~SD over five folds; our PlantVillage rows are single-split. Parameter counts marked $\approx $ are the standard ImageNet variants of the cited architectures, adjusted for the 38-class head; Too et al.\^^M\cite {too2019pruned} report their pruning as a relative reduction rather than an absolute count. Our parameter counts differ slightly between the two datasets because the classifier head is sized to the number of classes (38 for PlantVillage, 5 for Cassava); the backbones are identical}{table.7}{}}
